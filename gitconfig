[user]
  name = Rafael Lima
  email = contato@rafael.adm.br
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAYf6D20X8NGGQaIDRmO2KRhTydMUxopxVXWX/bPn6Px
[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true

[push]
  default = current
	autoSetupRemote = true
[alias]
  co = checkout
  l = log --graph --pretty=format':%C(yellow)%h%Cblue%d%Creset %s %C(white) %an, %ar%Creset'
  lol = log --pretty=oneline --abbrev-commit --graph --decorate
  gone = ! "git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -D"
[apply]
  whitespace = warn
[color]
  diff = auto
  status = auto
  branch = auto
  ui = true
[help]
  autocorrect = 1
[status]
  submodule = 1
[core]
	editor = code --wait
	excludesfile = /Users/rafael/.gitignore_global
[rerere]
  enabled = true
[branch]
  autosetuprebase = always
[github]
	user = rafaelp
[filter "hawser"]
	clean = git hawser clean %f
	smudge = git hawser smudge %f
	required = true
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
